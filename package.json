{
	"name": "casecellshop",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:server": "turbo -F @casecellshop/payment dev",
		"db:push": "turbo -F @casecellshop/db db:push",
		"db:studio": "turbo -F @casecellshop/db db:studio",
		"db:generate": "turbo -F @casecellshop/db db:generate",
		"db:migrate": "turbo -F @casecellshop/db db:migrate",
		"db:local": "turbo -F @casecellshop/payment db:local",
		"check": "biome check --write .",
		"prepare": "husky",
		"docker-build": "turbo docker-build --filter='[HEAD~1]'"
	},
	"dependencies": {
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@casecellshop/config": "workspace:*",
		"@casecellshop/shared": "workspace:*",
		"@types/node": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.9.4",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write"
		]
	},
	"packageManager": "pnpm@10.30.1"
}
