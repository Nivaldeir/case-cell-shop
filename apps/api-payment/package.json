{
	"name": "@ledger/api-payment",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./db/schema": "./src/infra/db/schema.ts"
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"test": "tsx --test --import ./__tests__/setup.ts __tests__/**/*.test.ts",
		"test:unit": "tsx --test --import ./__tests__/setup.ts __tests__/domain/**/*.test.ts __tests__/usecase/**/*.test.ts __tests__/controller/**/*.test.ts",
		"test:integration": "tsx --test --import ./__tests__/setup.ts __tests__/infra/**/*.test.ts",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.mjs",
		"db:local": "turso dev --db-file local.db",
		"db:push": "pnpm --filter @ledger/db run db:push",
		"db:generate": "pnpm --filter @ledger/db run db:generate",
		"db:studio": "pnpm --filter @ledger/db run db:studio",
		"db:migrate": "pnpm --filter @ledger/db run db:migrate",
		"db:migrate:kit": "pnpm --filter @ledger/db exec drizzle-kit migrate",
		"docker-build": "docker build --secret id=npm_token,env=NPM_TOKEN -f Dockerfile -t ledger/api-payment ../.."
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.992.0",
		"@aws-sdk/s3-request-presigner": "^3.992.0",
		"@ledger/db": "workspace:*",
		"@libsql/client": "^0.15.15",
"@ledger/shared": "workspace:*",
		"@mutual-processadora-de-pagamentos/lib-http-kit": "^2.0.2",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
		"@opentelemetry/resources": "^1.30.0",
		"@opentelemetry/sdk-node": "^0.57.0",
		"winston": "^3.17.0",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"express": "^5.1.0",
		"inversify": "^8.1.0",
		"multer": "^2.0.0",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@ledger/config": "workspace:*",
		"@testcontainers/postgresql": "^11.14.0",
		"@types/cors": "^2.8.17",
		"@types/express": "catalog:",
		"@types/multer": "^1.4.12",
		"@types/node": "catalog:",
		"@types/pg": "^8.20.0",
		"testcontainers": "^11.14.0",
		"tsdown": "^0.16.5",
		"tsx": "^4.19.2",
		"typescript": "catalog:"
	}
}
